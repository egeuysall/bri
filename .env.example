# Convex deployment used by `npx convex dev`.
CONVEX_DEPLOYMENT=""

# Public Convex deployment URL used by the Next.js app.
NEXT_PUBLIC_CONVEX_URL=""

# Public Convex site URL used for Convex HTTP actions.
NEXT_PUBLIC_CONVEX_SITE_URL=""

# Optional canonical site URL used for metadata generation.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Clerk publishable key used by Next.js frontend.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""

# Clerk secret key used on server.
CLERK_SECRET_KEY=""

# Clerk issuer domain used by Convex auth provider validation.
CLERK_JWT_ISSUER_DOMAIN=""

# Optional comma-separated admin identities (username or email).
BRIDGE_ADMIN_USERS=""

# Optional admin secret used by /api/admin/notes/* routes.
BRIDGE_ADMIN_SECRET=""

# Vercel AI Gateway key used server-side for note AI answers. Never expose with NEXT_PUBLIC_*.
AI_GATEWAY_API_KEY="vck_..."

# Model used by the note AI overlay and CLI ask command.
AI_GATEWAY_MODEL="openai/gpt-oss-20b"
