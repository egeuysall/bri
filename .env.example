# Public Supabase project URL used by the Next.js app.
NEXT_PUBLIC_SUPABASE_URL=""

# Public anon key for browser-safe Supabase access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Server-only key used by the Next.js app for direct database access.
# Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# Optional canonical site URL used for metadata generation.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
